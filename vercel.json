{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/api/ssr" }],
  "functions": {
    "api/ssr.ts": {
      "includeFiles": "dist/server/**",
      "maxDuration": 60
    }
  }
}
